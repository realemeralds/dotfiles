            "long long nCr (int n, int r) {",
            "    if (r > n - r) r = n - r; // because C(n, r) == C(n, n - r)",
            "    long long ans = 1;",
            "",
            "    for (int i = 1; i <= r; i++) {",
            "        ans *= n - r + i;",
            "        assert(ans > 0); // overflow check",
            "        ans /= i;",
            "    }",
            "",
            "    return ans;",
            "}",
