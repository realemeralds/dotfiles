    "Basic Geometry Functions": {
        "prefix": "geofns",
        "body": [
            "// point class from USACO (https://usaco.guide/plat/geo-pri)",
            "struct Point {",
            "    int x, y;",
            "    Point(int a = 0, int b = 0) : x(a), y(b) {}",
            "    Point operator-(const Point &other) { return {x - other.x, y - other.y}; }",
            "    friend istream &operator>>(istream &in, Point &p) {",
            "        in >> p.x >> p.y;",
            "        return in;",
            "    }",
            "};",
            "",
            "// function to check if point q lies on line segment 'pr'",
            "bool onSegment(const Point& p, const Point& q, const Point& r) {",
            "    return (q.x <= max(p.x, r.x) && ",
            "            q.x >= min(p.x, r.x) &&",
            "            q.y <= max(p.y, r.y) && ",
            "            q.y >= min(p.y, r.y));",
            "}",
            "",
            "// function to find orientation of ordered triplet (p, q, r)",
            "// 1 --> Counterclockwise",
            "// 0 --> p, q and r are collinear",
            "// -1 --> Clockwise",
            "int orientation(const Point& p, const Point& q, const Point& r) {",
            "    int val = (q.x - p.x) * (r.y - q.y) -",
            "              (q.y - p.y) * (r.x - q.x);",
            "    ",
            "    if (val == 0) return 0;",
            "    else if (val > 0) return 1;",
            "    else return -1;",
            "}",
            "",
            "",
            "// function to check if two line segments intersect",
            "bool doIntersect(const pair<Point, Point>& s1, const pair<Point, Point>& s2) {",
            "    // s1.first is p1, s1.second is q1;",
            "    // s2.first is p2, s2.second is q2;",
            "    ",
            "    ",
            "    // find the four orientations needed for general and special cases",
            "    int o1 = orientation(s1.first, s1.second, s2.first); // (p1, q1, s1)",
            "    int o2 = orientation(s1.first, s1.second, s2.second); // (p1, q1, s2)",
            "    int o3 = orientation(s2.first, s2.second, s1.first); // (p2, q2, s1)",
            "    int o4 = orientation(s2.first, s2.second, s1.second); // (p2, q2, s2)",
            "    ",
            "    // general case",
            "    if (o1 != o2 && o3 != o4)",
            "        return true;",
            "    ",
            "    // special cases",
            "    // p1, q1 and p2 are collinear and p2 lies on segment p1q1",
            "    if (o1 == 0 && onSegment(s1.first, s2.first, s1.second)) return true;",
            "    ",
            "    // p1, q1 and q2 are collinear and q2 lies on segment p1q1",
            "    if (o2 == 0 && onSegment(s1.first, s2.second, s1.second)) return true;",
            "    ",
            "    // p2, q2 and p1 are collinear and p1 lies on segment p2q2",
            "    if (o3 == 0 && onSegment(s2.first, s1.first, s2.second)) return true;",
            "    ",
            "    // p2, q2 and q1 are collinear and q1 lies on segment p2q2 ",
            "    if (o4 == 0 && onSegment(s2.first, s1.second, s2.second)) return true;",
            "    ",
            "    return false;",
            "}"
        ],
        "description": "Basic Geometry Functions"
    },
    "Segment Tree": {
        "prefix": "segtree",
        "body": [
            "class SegmentTree { // OOP style, default is used for range sum and range query",
            "private:",
            "    int n; // n = (int)A.size()",
            "    vi A; // array",
            "    vi st; // segment tree",
            "    vi lazy; // lazy flag, default is 0",
            "",
            "    int l(int p) { return p << 1; }       // go to left child",
            "    int r(int p) { return (p << 1) + 1; } // go to right child",
            "",
            "    int merge(int a, int b) {",
            "        return a + b;",
            "    }",
            "",
            "    void build(int p, int L, int R) { // O(n)",
            "        if (L == R) st[p] = A[L]; // base case",
            "        else {",
            "            int m = (L + R) / 2;",
            "            build(l(p), L, m);",
            "            build(r(p), m + 1, R);",
            "            st[p] = merge(st[l(p)], st[r(p)]);",
            "        }",
            "    }",
            "",
            "    void propagate(int p, int L, int R) { // updates current node, propagate lazy flag to children",
            "        if (lazy[p] != 0) {                 ",
            "            st[p] += lazy[p]; // update current node based on lazy     ",
            "",
            "            // propagation",
            "            if (L != R) { // not a leaf",
            "                lazy[l(p)] += lazy[p];",
            "                lazy[r(p)] += lazy[p];",
            "            }                            ",
            "            else { // L == R, a single index",
            "                A[L] += lazy[p];",
            "            }",
            "",
            "            lazy[p] = 0; // erase lazy flag",
            "        }",
            "    }",
            "",
            "    int query(int p, int L, int R, int i, int j) { // O(log n)",
            "        propagate(p, L, R); // lazy propagation of current node",
            "        if (i > j) return 0; // infeasible, return dummy variable",
            "        if ((L >= i) && (R <= j)) return st[p]; // found the segment",
            "        int m = (L + R) / 2;",
            "        return merge(query(l(p), L,   m, i,           min(m, j)),",
            "                     query(r(p), m+1, R, max(i, m+1), j));",
            "    }",
            "",
            "    void update(int p, int L, int R, int i, int j, int val) { // O(log n)",
            "        propagate(p, L, R); ",
            "        if (i > j) return;",
            "        if ((L >= i) && (R <= j)) { // found the segment",
            "            lazy[p] += val;      // update this",
            "            propagate(p, L, R); ",
            "        }",
            "        else {",
            "            int m = (L + R) / 2;",
            "            update(l(p), L,   m, i,           min(m, j), val);",
            "            update(r(p), m+1, R, max(i, m+1), j,         val);",
            "            st[p] = merge(st[l(p)], st[r(p)]);",
            "        }",
            "    }",
            "",
            "public: // wrapper fns",
            "    SegmentTree(int sz) : n(sz), A(n, 0), st(4*n, 0), lazy(4*n, 0) {}",
            "    SegmentTree(const vi &initialA) : SegmentTree((int)initialA.size()) {",
            "        A = initialA;",
            "        build(1, 0, n-1);",
            "    }",
            "    void update(int i, int j, int val) { update(1, 0, n-1, i, j, val); }",
            "    int query(int i, int j) { return query(1, 0, n-1, i, j); }",
            "};"
        ],
        "description": "Segment Tree"
    },
    "Trie": {
        "prefix": "triefn",
        "body": [
            "const int A = 26;",
            "",
            "struct Vertex {",
            "    int next[A]; // can be replaced with map<int, int> for large A.",
            "    bool output = false;",
            "",
            "    Vertex() { fill(begin(next), end(next), -1); }",
            "};",
            "",
            "struct Trie {",
            "private:",
            "    vector<Vertex> tr; // current Trie",
            "public:",
            "    Trie(): tr(1) {}",
            "    void addString(string const& s) {",
            "        int v = 0;",
            "        for (char ch : s) {",
            "            int c = ch - 'a';",
            "            if (tr[v].next[c] == -1) {",
            "                tr[v].next[c] = tr.size();",
            "                tr.emplace_back();",
            "            }",
            "            v = tr[v].next[c];",
            "        }",
            "        tr[v].output = true;",
            "    }",
            "    bool checkString(string const& s) {",
            "        int v = 0;",
            "        for (char ch: s) {",
            "            int c = ch - 'a';",
            "            if (tr[v].next[c] == -1) return false;",
            "            v = tr[v].next[c];",
            "        }",
            "        return tr[v].output;",
            "    }",
            "};"
        ],
        "description": "Trie"
    }
}