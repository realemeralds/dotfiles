    "UFDS": {
        "prefix": "ufdsfn",
        "body": [
            "int parent[N+1];",
            "",
            "int root(int x) {",
            "    if (parent[x]==-1) return x;",
            "    int r = root(parent[x]);",
            "    parent[x] = r;",
            "    return r;",
            "}",
            "",
            "bool isConnected(int x, int y) {",
            "    return root(x) == root(y);",
            "}",
            "",
            "void connect(int x, int y) {",
            "    int rootX = root(x);",
            "    int rootY = root(y);",
            "    if(rootX != rootY) parent[rootX] = rootY;",
            "}",
            "$0"
        ],
        "description": "UFDS"
    },
    "Fenwick Tree": {
        "prefix": "fentree",
        "body": [
            "long long ft[N + 1]; // 1-indexed",
            "",
            "long long fenwick_query(int p) {",
            "    long long sum = 0;",
            "    while (p) { // while p > 0",
            "        sum += ft[p];",
            "        p -= p & -p;",
            "    }",
            "    return sum;",
            "}",
            "",
            "void fenwick_update(int p, long long v) {",
            "    while (p <= N) {",
            "        ft[p] += v;",
            "        p += p & -p;",
            "    }",
            "}",
            "$0"
        ],
        "description": "Fenwick Tree"
