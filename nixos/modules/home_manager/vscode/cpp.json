            "int ncr[1000][1000]; ",
            "// N is the maximum value of N that will be requested.",
            "void makeTriangle (int N) {",
            "int i, j;",
            "",
            "// initialize the first row",
            "ncr[0][0] = 1; // C(0, 0) = 1",
            "",
            "for (i = 1; i < N; i++) {",
            "    ncr[i][0] = 1; // C(i, 0) = 1",
            "        for(j = 1; j <= i; j++) {",
            "            ncr[i][j] = ncr[i - 1][j - 1] + ncr[i - 1][j];",
            "            ncr[i][j] %= MOD; ",
            "        }",
